{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["site", "home", "posts", "nav"],
  "properties": {
    "site": {
      "type": "object",
      "required": ["name", "tagline", "url"],
      "properties": {
        "name": { "type": "string", "nonEmptyString": true },
        "tagline": { "type": "string", "nonEmptyString": true },
        "url": {
          "type": "string",
          "nonEmptyString": true,
          "pattern": "^https?://"
        },
        "logo": { "type": "string" },
        "footer": { "type": "string" }
      },
      "additionalProperties": true
    },
    "home": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string", "nonEmptyString": true },
        "subtitle": { "type": "string" }
      },
      "additionalProperties": true
    },
    "posts": {
      "type": "object",
      "validDefaultTag": true,
      "required": ["pageTitle", "defaultTag", "tags"],
      "properties": {
        "pageTitle": { "type": "string", "nonEmptyString": true },
        "defaultTag": { "type": "string", "nonEmptyString": true },
        "tags": {
          "type": "object",
          "minProperties": 1,
          "patternProperties": {
            "^[a-z0-9-]+$": {
              "oneOf": [
                { "type": "string", "nonEmptyString": true },
                {
                  "type": "object",
                  "required": ["label"],
                  "properties": {
                    "label": { "type": "string", "nonEmptyString": true },
                    "color": { "type": "string", "cssNamedColor": true }
                  },
                  "additionalProperties": false
                }
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "theme": {
      "type": "object",
      "properties": {
        "background": {
          "type": "object",
          "properties": {
            "type": { "enum": ["solid", "gradient", "image"] },
            "color": { "type": "string" },
            "gradientStart": { "type": "string" },
            "gradientEnd": { "type": "string" },
            "image": { "type": "string" },
            "repeat": { "type": "string" },
            "position": { "type": "string" },
            "size": { "type": "string" }
          },
          "if": {
            "properties": { "type": { "const": "image" } },
            "required": ["type"]
          },
          "then": {
            "required": ["image"],
            "properties": {
              "image": { "type": "string", "nonEmptyString": true }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "nav": {
      "type": "object",
      "required": ["links"],
      "properties": {
        "links": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "object",
                "required": ["type", "label", "href"],
                "properties": {
                  "type": { "const": "text" },
                  "label": { "type": "string", "nonEmptyString": true },
                  "href": { "type": "string", "nonEmptyString": true }
                },
                "additionalProperties": false
              },
              {
                "type": "object",
                "required": ["type", "label", "href", "icon"],
                "properties": {
                  "type": { "const": "icon" },
                  "label": { "type": "string", "nonEmptyString": true },
                  "href": { "type": "string", "nonEmptyString": true },
                  "icon": { "type": "string", "nonEmptyString": true }
                },
                "additionalProperties": false
              }
            ]
          }
        }
      },
      "additionalProperties": true
    },
    "sidebar": {
      "type": "object",
      "properties": {
        "cta": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "heading": { "type": "string" },
            "text": { "type": "string" },
            "buttonText": { "type": "string" },
            "buttonHref": { "type": "string" }
          },
          "if": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          },
          "then": {
            "required": ["buttonHref"],
            "properties": {
              "buttonHref": { "type": "string", "nonEmptyString": true }
            }
          },
          "additionalProperties": true
        },
        "status": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "status": {
      "type": "object",
      "properties": {
        "plugin": { "enum": ["mock", "tcp-check", "http"] },
        "options": { "type": "object" }
      },
      "if": {
        "properties": { "plugin": { "const": "http" } },
        "required": ["plugin"]
      },
      "then": {
        "required": ["options"],
        "properties": {
          "options": {
            "type": "object",
            "required": ["url"],
            "properties": {
              "url": { "type": "string", "nonEmptyString": true }
            }
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
