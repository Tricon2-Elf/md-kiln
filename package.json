{
  "name": "mdkiln",
  "version": "1.0.0",
  "description": "Pre-rendered markdown site generator",
  "main": "build/server.js",
  "scripts": {
    "compile": "tsc",
    "build": "npm run compile && node build/scripts/build.js",
    "start": "npm run compile && node build/server.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "compression": "^1.8.1",
    "ejs": "^3.1.10",
    "express": "^4.22.2",
    "feed": "^5.2.1",
    "gray-matter": "^4.0.3",
    "helmet": "^8.2.0",
    "html-minifier-terser": "^7.2.0",
    "marked": "^15.0.12",
    "sitemap": "^8.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "prettier": "^3.8.4",
    "typescript": "^5.7.2"
  }
}
